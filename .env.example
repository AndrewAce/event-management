# PostgreSQL database URL (e.g. from Supabase or Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase project config — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Used to sync Supabase auth user to Prisma User table on first sign-in
# Set this to your app's base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
